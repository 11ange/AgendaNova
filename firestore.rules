rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES DE VALIDAÇÃO ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email != null && (
        request.auth.token.email == 'luis.lange@gmail.com' ||
        request.auth.token.email == 'admin@agendanova.com' || 
        request.auth.token.email.matches('.*@admin\\.agendanova\\.com$')
      );
    }

    // Verifica se o usuário logado é o dono do documento ou admin
    // Útil para leitura (get/list) onde o resource pode ser null
    function canAccess(res) {
      return isAuthenticated() && (
        res == null || 
        isAdmin() || 
        (res.data.keys().hasAll(['ownerId']) && res.data.ownerId == request.auth.uid)
      );
    }

    function validateString(field, minLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() >= minLen;
    }

    function validateEnum(field, allowedValues) {
      return request.resource.data[field] in allowedValues;
    }

    // --- REGRAS POR COLECÇÃO ---

    // 1. Pacientes
    match /pacientes/{pacienteId} {
      allow read, delete: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update: if canAccess(resource) && canAccess(request.resource);
      
      allow create, update: if 
        validateString('nome', 2) &&
        request.resource.data.dataNascimento is string &&
        validateEnum('status', ['ativo', 'inativo', 'arquivado']);
    }

    // 2. Lista de Espera
    match /lista_espera/{entryId} {
      allow read, delete: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update: if canAccess(resource) && canAccess(request.resource);
    }

    // 3. Disponibilidade (Agenda)
    match /disponibilidade/{docId} {
      allow read, delete: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update: if canAccess(resource) && canAccess(request.resource);
    }

    // 4. Treinamentos
    match /treinamentos/{treinamentoId} {
      allow read, delete: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update: if canAccess(resource) && canAccess(request.resource);
    }

    // 5. Sessões Agendadas
    match /sessoes_agendadas/{sessaoId} {
      allow read, delete: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update: if canAccess(resource) && canAccess(request.resource);
    }

    // 6. Pagamentos
    match /pagamentos/{pagamentoId} {
      allow read, delete: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update: if canAccess(resource) && canAccess(request.resource);
    }

    // 7. Relatórios
    match /relatorios/{relatorioId} {
      allow read: if canAccess(resource);
      allow create: if isAuthenticated() && canAccess(request.resource);
      allow update, delete: if false;
    }
  }
}